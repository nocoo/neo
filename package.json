    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
