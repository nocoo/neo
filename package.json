{
  "name": "neo",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 7042",
    "build": "next build",
    "start": "next start -p 7042",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest",
